#!/usr/bin/env bash
#
# Pre-commit hook: block personal data from being committed.
#
# Reads patterns from data/config/ files (names, activities, locations)
# and checks staged files for matches. This is a safety net — the primary
# guard is Claude validating before writing.

set -euo pipefail

# Only check tracked (non-gitignored) files that are staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -v '^data/' || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Build patterns from config files if they exist
PATTERNS_FILE=$(mktemp)
trap "rm -f $PATTERNS_FILE" EXIT

# Extract personal names/terms from config files
# Each household will have different sensitive terms
SENSITIVE_TERMS_FILE="data/config/.sensitive-terms"

if [ ! -f "$SENSITIVE_TERMS_FILE" ]; then
    # No sensitive terms configured — skip check
    exit 0
fi

# Read terms (one per line, lines starting with # are comments)
PATTERNS=$(grep -v '^#' "$SENSITIVE_TERMS_FILE" | grep -v '^$' || true)

if [ -z "$PATTERNS" ]; then
    exit 0
fi

FOUND=0

while IFS= read -r pattern; do
    # Case-insensitive search in added lines only (lines starting with +, not ++)
    MATCHES=$(git diff --cached -U0 -- $STAGED_FILES | grep '^+' | grep -v '^+++' | grep -i "$pattern" || true)
    if [ -n "$MATCHES" ]; then
        if [ "$FOUND" -eq 0 ]; then
            echo ""
            echo "ERROR: Personal data detected in staged changes!"
            echo "======================================================="
        fi
        FOUND=1
        echo ""
        echo "  Pattern: '$pattern'"
        echo "  Matches:"
        echo "$MATCHES" | head -5 | sed 's/^/    /'
    fi
done <<< "$PATTERNS"

if [ "$FOUND" -ne 0 ]; then
    echo ""
    echo "======================================================="
    echo "Personal data must stay in data/ (gitignored)."
    echo "Use generic terms (caregiver, tech partner, Kid 1, etc.)"
    echo ""
    echo "If this is a false positive, review and commit with --no-verify."
    echo ""
    exit 1
fi

exit 0
